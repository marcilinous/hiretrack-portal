# Normalize line endings: store text as LF in the repo, check out as-is.
# Stops the recurring "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Explicit text types (force LF regardless of detection)
*.html  text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.svg   text eol=lf
*.xml   text eol=lf

# Binary assets — never normalize or diff as text
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
